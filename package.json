{
  "name": "drug-interaction-system",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "dev:frontend": "pnpm --filter @drug-interaction/frontend dev",
    "dev:backend": "pnpm --filter @drug-interaction/backend dev",
    "build:frontend": "pnpm --filter @drug-interaction/frontend build",
    "build:backend": "pnpm --filter @drug-interaction/backend build",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}
