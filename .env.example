# 药物相互作用系统 - 环境变量示例
# 复制此文件以在相应的工作空间目录中创建您自己的.env文件

# =============================================================================
# 前端环境变量 (apps/frontend/.env)
# =============================================================================

# API基础URL - 后端API端点
# 开发环境: 使用/api进行代理或http://localhost:3000/api进行直接连接
# 生产环境: 使用/进行Netlify代理或您部署的后端URL
VITE_API_BASE_URL=/api

# API请求超时时间（毫秒）
# 开发环境: 10000（10秒）
# 生产环境: 30000（30秒）用于较慢的网络条件
VITE_API_TIMEOUT=10000

# =============================================================================
# 后端环境变量 (apps/backend/.env)
# =============================================================================

# 服务器配置
PORT=3000
NODE_ENV=development

# MongoDB配置
# 本地开发: mongodb://localhost:27017/
# 生产环境: mongodb://username:password@host:port/
MONGODB_URI=mongodb://localhost:27017/
DB_NAME=drug_interaction_db

# DeepSeek AI API配置
# 从以下地址获取您的API密钥: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
AI_TIMEOUT=300000

# 日志配置
# 选项: error, warn, info, debug
LOG_LEVEL=info

# =============================================================================
# 注意事项
# =============================================================================
# 1. 前端环境变量必须以VITE_前缀开头才能被暴露
# 2. 切勿将包含敏感数据的实际.env文件提交到版本控制
# 3. 每个工作空间（frontend/backend）都应该有自己的.env文件
# 4. 复制此示例并创建:
#    - apps/frontend/.env（用于前端开发）
#    - apps/backend/.env（用于后端开发）